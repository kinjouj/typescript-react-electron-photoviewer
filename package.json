{
  "name": "photoviewer",
  "version": "0.0.1",
  "author": "kinjouj",
  "main": "dist/main.js",
  "license": "MIT",
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "eslint --cache --cache-location=node_modules/.eslintcache",
    "build": "npm run check && npm run lint && vite build",
    "start": "electron .",
    "package": "electron-builder --config builder.json",
    "package:linux": "electron-builder --config builder.json --linux"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "electron": "^41.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vite-plugin-electron": "^0.29.0"
  },
  "dependencies": {
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-spinners": "^0.17.0",
    "swiper": "^12.1.2"
  }
}
